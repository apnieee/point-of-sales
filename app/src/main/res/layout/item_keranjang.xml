<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="4dp"
    android:paddingVertical="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvProdukKeranjang"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivProdukKeranjang"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Foto Isian Seblak"
            android:scaleType="centerCrop"
            android:src="@drawable/productjg" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvNamaProdukKeranjang"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Nama Isian Seblak"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvSubtotalItem"
        app:layout_constraintStart_toEndOf="@id/cvProdukKeranjang"
        app:layout_constraintTop_toTopOf="@id/cvProdukKeranjang" />

    <TextView
        android:id="@+id/tvHargaSatuanKeranjang"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Rp 0"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/tvNamaProdukKeranjang"
        app:layout_constraintStart_toStartOf="@id/tvNamaProdukKeranjang"
        app:layout_constraintTop_toBottomOf="@id/tvNamaProdukKeranjang" />


    <TextView
        android:id="@+id/tvSubtotalItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:minWidth="80dp"
        android:text="Rp 0"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/cvProdukKeranjang" />

    <ImageView
        android:id="@+id/btnTambahKeranjang"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/bg_btn_outline"
        android:contentDescription="Tambah Qty"
        android:padding="4dp"
        android:src="@drawable/plus"
        app:layout_constraintBottom_toBottomOf="@id/cvProdukKeranjang"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/tvQtyKeranjang"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="1"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnTambahKeranjang"
        app:layout_constraintEnd_toStartOf="@id/btnTambahKeranjang"
        app:layout_constraintTop_toTopOf="@id/btnTambahKeranjang" />

    <ImageView
        android:id="@+id/btnKurangKeranjang"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:padding="4dp"
        android:src="@drawable/minus"
        app:layout_constraintBottom_toBottomOf="@id/btnTambahKeranjang"
        app:layout_constraintEnd_toStartOf="@id/tvQtyKeranjang"
        app:layout_constraintTop_toTopOf="@id/btnTambahKeranjang"
        app:tint="?android:attr/textColorPrimary" />

</androidx.constraintlayout.widget.ConstraintLayout>