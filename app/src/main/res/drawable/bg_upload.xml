<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="@color/upload_bg"/>
            <corners android:radius="20dp"/>

            <stroke
                android:width="3dp"
                android:color="@color/upload_stroke"/>
        </shape>
    </item>

    <item
        android:height="80dp"
        android:gravity="bottom">

        <shape>
            <solid android:color="@color/upload_bottom"/>

            <corners
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="20dp"/>
        </shape>
    </item>

</layer-list>